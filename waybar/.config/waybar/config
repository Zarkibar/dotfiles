{
  "layer": "top",
  "position": "top",
  "height": 34,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["hyprland/workspaces", "tray", "custom/screenrecord"],
  "modules-center": ["clock", "custom/power"],
  "modules-right": ["pulseaudio", "network", "cpu", "memory"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

  "tray": {
		  "icon-size": 20,
		  "spacing": 10
  },

  "custom/screenrecord": {
		  "exec": "~/.config/waybar/scripts/screenrecord.sh",
		  "return-type": "json",
		  "interval": 1,
		  "format": "{text}",
		  "tooltip": true
  },

  "custom/power": {
		  "format": "⏻",
		  "on-click": "~/.config/waybar/scripts/power-menu.sh",
		  "tooltip": false
  },

  "clock": {
    "format": "{:%A, %d %B %Y, %I:%M %p}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "format-alt": "  {:%I:%M %p}"
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "  muted",
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "󰈀  Wired",
    "format-disconnected": "⚠  Offline"
  },

  "cpu": {
    "interval": 1,
    "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"],
    "on-click": "ghostty -e htop"
  },

  "memory": {
    "interval": 30,
    "format": "  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },
}
