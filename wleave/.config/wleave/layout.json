{
  "margin": "18%",
  "buttons-per-row": "1/1",
  "column-spacing": "16px",
  "row-spacing": "0px",
  "close-on-lost-focus": true,
  "show-keybinds": false,
  "buttons": [
    {
      "label": "lock",
      "action": "loginctl lock-session",
      "text": "Lock",
      "keybind": "l"
    },
    {
      "label": "sleep",
      "action": "systemctl suspend",
      "text": "Sleep",
      "keybind": "s"
    },
    {
      "label": "reboot",
      "action": "systemctl reboot",
      "text": "Reboot",
      "keybind": "r"
    },
    {
      "label": "poweroff",
      "action": "systemctl poweroff",
      "text": "Power Off",
      "keybind": "p"
    }
  ]
}
